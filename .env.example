# Django
DJANGO_SECRET_KEY=replace-this-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# NOTE: DJANGO_SETTINGS_MODULE is intentionally NOT set here. It's
# determined by how you run the app (manage.py defaults to development,
# Docker Compose services hardcode production in their `environment:`
# block, wsgi.py/asgi.py default to production) — not by .env, so a
# stray value here can never silently flip a production container into
# development/DEBUG mode.

# Database (PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=swapi_platform
DB_USER=swapi_user
DB_PASSWORD=swapi_password
DB_HOST=db
DB_PORT=5432

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# JWT
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# SWAPI
SWAPI_BASE_URL=https://swapi.dev/api
SWAPI_REQUEST_TIMEOUT=10
SWAPI_MAX_RETRIES=3
SWAPI_RETRY_BACKOFF_SECONDS=1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
